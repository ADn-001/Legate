# App
SECRET_KEY=<long-random-string>
DEBUG=false
ENVIRONMENT=development

# Database (Supabase)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Redis
REDIS_URL=redis://localhost:6379/0

# Email (Resend)
RESEND_API_KEY=<resend-api-key>
EMAIL_FROM=noreply@legate.app

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Supabase JWT + delivery
SUPABASE_JWT_SECRET=<supabase-jwt-secret>
DELIVERY_SECRET=<long-random-string>
# Base URL used in outbound email links. In production set to the public
# origin + /api (e.g. https://your-host/api) so links resolve through nginx.
BASE_URL=http://localhost:8000

# Key derivation
PBKDF2_ITERATIONS=100000

# CORS — comma-separated allowed origins; empty = dev localhost defaults
CORS_ORIGINS=

# ASGI root path when behind a prefix-stripping proxy (compose sets /api)
ROOT_PATH=

# Supabase Storage buckets
SUPABASE_STORAGE_BUCKET_CONTENT=capsule-content
SUPABASE_STORAGE_BUCKET_MEDIA=media-attachments
SUPABASE_STORAGE_BUCKET_THUMBNAILS=thumbnails

# Per-user storage quota in bytes (FR-36 progress bar); default 1 GiB
STORAGE_QUOTA_BYTES=1073741824

# Internal operational alerts (permanent delivery failures, FR-42).
# Empty disables alert emails; audit rows are always written.
ALERT_EMAIL=

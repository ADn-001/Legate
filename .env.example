# Root env consumed by docker compose (cp .env.example .env, then fill in).
# Postgres connection string for the managed Supabase database
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# REDIS_URL is internal to the compose network (redis://redis:6379/0) — no need to set it here
# Supabase project URL
SUPABASE_URL=https://<project-ref>.supabase.co
# Supabase anon (public) API key
SUPABASE_ANON_KEY=<anon-key>
# Supabase service-role key (server-side only; keep secret)
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# Supabase JWT signing secret (Project Settings -> API)
SUPABASE_JWT_SECRET=<supabase-jwt-secret>
# Resend API key for outbound email
RESEND_API_KEY=<resend-api-key>
# From-address for outbound email
EMAIL_FROM=noreply@legate.app
# App secret key (long random string)
SECRET_KEY=<long-random-string>
# Secret for delivery-token signing (long random string)
DELIVERY_SECRET=<long-random-string>
# Public base URL used in email links; in production: public origin + /api (e.g. https://your-host/api)
BASE_URL=http://localhost/api
# Comma-separated allowed CORS origins; empty = dev localhost defaults
CORS_ORIGINS=
# development | production
ENVIRONMENT=development
# PBKDF2 iteration count for key derivation
PBKDF2_ITERATIONS=100000
# Supabase Storage bucket names
SUPABASE_STORAGE_BUCKET_CONTENT=capsule-content
SUPABASE_STORAGE_BUCKET_MEDIA=media-attachments
SUPABASE_STORAGE_BUCKET_THUMBNAILS=thumbnails
# Host port nginx publishes (container always listens on 80)
NGINX_PORT=80
